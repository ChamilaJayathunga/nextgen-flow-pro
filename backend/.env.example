# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nextgen_flow_pro

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Upload
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=debug

# AI Video Generation Providers
GOOGLE_FLOW_API_KEY=your-google-flow-api-key
OPENAI_API_KEY=your-openai-api-key
RUNWAY_API_KEY=your-runway-api-key
PIKA_API_KEY=your-pika-api-key
LUMA_API_KEY=your-luma-api-key
KLING_API_KEY=your-kling-api-key
PIXVERSE_API_KEY=your-pixverse-api-key
HAILUO_API_KEY=your-hailuo-api-key
STABILITY_API_KEY=your-stability-api-key
REPLICATE_API_KEY=your-replicate-api-key
FAL_API_KEY=your-fal-api-key
